{
  "name": "rnxj-dev",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && bun run scripts/prerender.tsx",
    "preview": "vite preview",
    "preview:cloudflare": "bun run build && wrangler dev",
    "deploy:dry-run": "bun run build && wrangler deploy --dry-run",
    "deploy": "bun run build && wrangler deploy",
    "lint": "oxlint",
    "format": "oxfmt --write .",
    "check": "oxlint && oxfmt --write .",
    "check-types": "tsc",
    "prepare": "lefthook install"
  },
  "dependencies": {
    "gsap": "3.15.0",
    "lenis": "1.3.25",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "lefthook": "2.1.10",
    "oxfmt": "0.58.0",
    "oxlint": "1.73.0",
    "typescript": "7.0.2",
    "vite": "8.1.4",
    "wrangler": "4.110.0"
  }
}
