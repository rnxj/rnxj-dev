{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "rnxj-dev",
  "compatibility_date": "2026-07-13",
  "workers_dev": false,
  "preview_urls": false,
  "routes": [
    {
      "pattern": "rnxj.dev",
      "custom_domain": true,
    },
  ],
  "assets": {
    "directory": "./dist",
    "not_found_handling": "none",
    "run_worker_first": false,
  },
}
